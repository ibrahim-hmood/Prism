<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:padding="24dp">

    <!-- Glowing Border Frame -->
    <FrameLayout
        android:id="@+id/dialogGlowFrame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="2dp">

        <!-- Main Dialog Content Container -->
        <LinearLayout
            android:id="@+id/dialogContentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E61A1A1A"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/dialogTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dialog Title"
                android:textColor="@color/prism_text_primary"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/dialogMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Dialog message goes here."
                android:textColor="@color/prism_text_muted"
                android:textSize="14sp" />

            <ProgressBar
                android:id="@+id/dialogProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:progressDrawable="@drawable/bg_prism_progress"
                android:visibility="gone" />

            <!-- Custom View Container -->
            <FrameLayout
                android:id="@+id/dialogCustomView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="end"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/dialogNegativeBtn"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cancel"
                    android:textColor="@color/prism_text_muted" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/dialogPositiveBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="OK" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
