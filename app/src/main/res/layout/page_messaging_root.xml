<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Messages"
            android:textColor="@color/prism_text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-medium" />
    </RelativeLayout>

    <!-- Messaging Search Box -->
    <FrameLayout
        android:id="@+id/messagingSearchContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:padding="8dp">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/messagingSearchLayout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundColor="#1AFFFFFF"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusTopStart="16dp"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp"
            app:hintEnabled="false"
            app:startIconDrawable="@drawable/ic_search_24"
            app:startIconTint="@color/prism_text_muted">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/messagingSearchInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Search messages..."
                android:inputType="text"
                android:paddingVertical="10dp"
                android:textColor="@color/prism_text_primary"
                android:textColorHint="@color/prism_text_muted"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>
    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/messagingConversationList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="80dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/messagingRequestPermissionBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Grant Permissions"
            android:visibility="gone" />
    </FrameLayout>
</LinearLayout>
