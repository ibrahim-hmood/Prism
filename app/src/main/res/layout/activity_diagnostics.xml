<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Ubuntu Title Bar Mockup -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#3d3d3d"
        android:orientation="horizontal"
        android:padding="4dp">
        
        <View android:layout_width="10dp" android:layout_height="10dp"
            android:layout_margin="2dp" android:background="@drawable/circle_red" />
        <View android:layout_width="10dp" android:layout_height="10dp"
            android:layout_margin="2dp" android:background="@drawable/circle_orange" />
        <View android:layout_width="10dp" android:layout_height="10dp"
            android:layout_margin="2dp" android:background="@drawable/circle_green" />
            
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="prism@mesh: ~"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:textSize="10sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#000000" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/log_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical" />
        
</LinearLayout>
